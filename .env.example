APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Broadcasting Configuration
BROADCAST_CONNECTION=pusher

# Pusher Configuration (Soketi local WebSocket server - free, self-hosted)
PUSHER_APP_ID=local
PUSHER_APP_KEY=local
PUSHER_APP_SECRET=local
PUSHER_APP_HOST=127.0.0.1
PUSHER_APP_PORT=6001
PUSHER_APP_SCHEME=http
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
VITE_PUSHER_APP_HOST="${PUSHER_APP_HOST}"
VITE_PUSHER_APP_PORT="${PUSHER_APP_PORT}"
VITE_PUSHER_APP_SCHEME="${PUSHER_APP_SCHEME}"

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Asterisk AMI Configuration
ASTERISK_AMI_HOST=127.0.0.1
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USERNAME=admin
ASTERISK_AMI_SECRET=password
ASTERISK_AMI_CONNECT_TIMEOUT=10
ASTERISK_AMI_READ_TIMEOUT=5

# Asterisk ARI Configuration
ASTERISK_ARI_HOST=127.0.0.1
ASTERISK_ARI_PORT=8088
ASTERISK_ARI_USERNAME=asterisk
ASTERISK_ARI_PASSWORD=asterisk
ASTERISK_ARI_APP_NAME=pbx-control-panel
ASTERISK_ARI_CONNECT_TIMEOUT=10
ASTERISK_ARI_READ_TIMEOUT=30

# Asterisk General Settings
ASTERISK_AUTO_CONNECT=true
ASTERISK_RETRY_INTERVAL=30
ASTERISK_MAX_RETRIES=5
ASTERISK_CACHE_TTL=60
ASTERISK_LOG_EVENTS=true

# Asterisk Events
ASTERISK_EVENTS_ENABLED=true
ASTERISK_EVENTS_QUEUE=asterisk-events
ASTERISK_EVENTS_CHANNEL=asterisk-events
ASTERISK_HEARTBEAT_INTERVAL=30

# Asterisk Recording
ASTERISK_RECORDING_ENABLED=true
ASTERISK_RECORDING_FORMAT=wav
ASTERISK_RECORDING_DIR=/var/spool/asterisk/monitor
ASTERISK_MAX_RECORDING_DURATION=3600
ASTERISK_MAX_RECORDING_SILENCE=30
